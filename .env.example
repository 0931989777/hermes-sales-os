# Server
PORT=3020
PUBLIC_WEBHOOK_PATH=/webhook

# Meta Messenger
# Long tu dat mot chuoi bi mat bat ky, roi nhap y het vao Meta Webhook Verify Token.
META_VERIFY_TOKEN=change-me
META_PAGE_ACCESS_TOKEN=EAAB...
META_PAGE_ACCESS_TOKENS=PAGE_ID=EAAB...,PAGE_ID_2=EAAB...
META_PAGE_ACCESS_TOKENS_EXTRA=

# Optional but recommended: Meta App Secret de verify X-Hub-Signature-256.
META_APP_SECRET=
META_GRAPH_API_VERSION=v23.0

# OpenClaw Gateway
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_AUTH_TOKEN=
OPENCLAW_MODEL=openclaw/default
# auto = thu HTTP /v1/chat/completions truoc, neu chua bat thi fallback CLI.
# http = chi dung HTTP. cli = chi dung `openclaw agent --json`.
OPENCLAW_TRANSPORT=auto
OPENCLAW_CLI_BIN=openclaw
OPENCLAW_CLI_TIMEOUT_SECONDS=180

# Optional behavior
BOT_SYSTEM_PROMPT=Ban la tro ly AI tra loi tren Facebook Messenger. Tra loi bang tieng Viet, ngan gon, than thien, va hoi lai khi chua ro.
MAX_REPLY_CHARS=1900
MESSENGER_POLL_FALLBACK_ENABLED=false
MESSENGER_POLL_INTERVAL_SECONDS=30
MESSENGER_POLL_LOOKBACK_SECONDS=3600
MESSENGER_POLL_MIN_MESSAGE_AGE_SECONDS=20
MESSENGER_POLL_MAX_CONVERSATIONS=20
COMMENT_POLL_FALLBACK_ENABLED=false
COMMENT_POLL_INTERVAL_SECONDS=60
COMMENT_POLL_LOOKBACK_SECONDS=86400
COMMENT_POLL_MAX_POSTS=10
COMMENT_POLL_MAX_COMMENTS_PER_POST=25
